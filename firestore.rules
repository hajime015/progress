rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check ownership
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Catalogs: read/write allowed if authenticated
    match /catalogs/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Orders: read/write allowed for owner
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
